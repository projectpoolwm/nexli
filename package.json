                         "cors":  "^2.8.6",
                         "dotenv":  "^17.2.3",
                         "express":  "^4.22.1",
                         "jsonwebtoken":  "^9.0.3",
                         "lucide-react":  "^0.546.0",
                         "motion":  "^12.23.24",
                         "multer":  "^2.1.1",
                         "react":  "^19.0.0",
                         "react-dom":  "^19.0.0",
                         "socket.io":  "^4.8.3",
                         "socket.io-client":  "^4.8.3",
                         "uuid":  "^13.0.0",
                         "vite":  "^6.2.0"
                     },
