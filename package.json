{
    "name":  "react-example",
    "private":  true,
    "version":  "0.0.0",
    "type":  "commonjs",
    "scripts":  {
                    "dev":  "tsx watch server.ts",
                    "dev:frontend":  "vite",
                    "build":  "vite build",
                    "build:backend":  "tsc -p tsconfig.json",
                    "preview":  "vite preview",
                    "start":  "node dist-server/server.js",
                    "start:prod":  "npm run build:backend \u0026\u0026 npm run start",
                    "start:tsx":  "tsx server.ts",
                    "start:tsnode:cjs":  "node -r ts-node/register/transpile-only server.ts",
                    "start:tsnode:esm":  "node --loader ts-node/esm server.ts",
                    "pm2:start":  "pm2 start ecosystem.config.js --env production",
                    "pm2:restart":  "pm2 restart ecosystem.config.js --env production",
                    "pm2:logs":  "pm2 logs sadvrfqtvw4-backend"
                },
    "dependencies":  {
                         "@google/genai":  "^1.29.0",
